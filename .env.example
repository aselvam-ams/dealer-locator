# --- Database ---
DATABASE_URL=postgres://dealer:dealer@localhost:5433/dealer_locator

# --- Server ---
PORT=4000
# Secret used to sign JWTs. Change in any real deployment.
JWT_SECRET=dev-only-change-me
# Comma-separated list of origins allowed to call the API / embed the iframe.
# Phase 1 mock: include the Salesforce org domain(s) here.
ALLOWED_ORIGINS=http://localhost:5173,https://example.my.salesforce.com
# Origins allowed to frame the /embed route (CSP frame-ancestors).
FRAME_ANCESTORS=https://example.my.salesforce.com

# --- Mock SFTP (Change Register outbound) ---
# Local folder used by the mock SFTP deliverer to drop club delta files.
SFTP_OUT_DIR=./sftp-out

# --- Google Maps (optional; mock used when absent) ---
# Leave blank to use the deterministic mock routing provider.
GOOGLE_MAPS_API_KEY=

# --- Web ---
VITE_API_BASE=http://localhost:4000
# Optional browser maps key; blank -> static placeholder map.
VITE_GOOGLE_MAPS_API_KEY=
